<?xml version="1.0" encoding="utf-8" ?>
<abstract:BaseContentPage  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="MauiClient.UI.Pages.RescheduleReminderView"
             xmlns:abstract="clr-namespace:MauiClient.UI.Abstract"
             xmlns:vm="clr-namespace:MauiClient.ViewModels"
             x:DataType="vm:RescheduleReminderViewModel"
             Title="Reschedule Reminder">
    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <StackLayout Orientation="Vertical" Padding="15">
            <Label 
               Text="Last scheduled date"
               Margin="0,15,0,0"/>
            <DatePicker
               x:Name="LastScheduledDate"
               Date="{Binding NewSchedule.LastScheduledDate}"/>

            <Label 
               Text="Scheduled date"
               Margin="0,15,0,0"/>
            <DatePicker
               x:Name="ScheduledDate"
               Date="{Binding NewSchedule.ScheduledDate}"/>

            <Label 
               Text="Send notifications?"
               Margin="0,15,0,0"/>
            <Switch  
               x:Name="SendNotifications"
               HorizontalOptions="Start"
               IsToggled="{Binding NewSchedule.SendNotifications}"/>

            <Label 
               IsVisible="{Binding IsToggled, Source={x:Reference SendNotifications}}"
               Text="Notifications start before (days)"
               Margin="0,15,0,0"/>
            <Entry 
               x:Name="NotificationsStartBeforeInDays"
               IsVisible="{Binding IsToggled, Source={x:Reference SendNotifications}}"
               HorizontalOptions="Fill"
               Keyboard="Numeric"
               Text="{Binding NewSchedule.NotificationsStartBeforeInDays}"/>

            <Label 
               IsVisible="{Binding IsToggled, Source={x:Reference SendNotifications}}"
               Text="Notifications interval (days)"
               Margin="0,15,0,0"/>
            <Entry 
               x:Name="NotificationsIntervalInDays"
               IsVisible="{Binding IsToggled, Source={x:Reference SendNotifications}}"
               HorizontalOptions="Fill"
               Keyboard="Numeric"
               Text="{Binding NewSchedule.NotificationsIntervalInDays}"/>

            <Button Text="Submit" Command="{Binding SubmitCommand}" Margin="0,15,0,0"></Button>

            <Label 
               Text="{Binding ValidationErrorMessage}"
               TextColor="Red"
               Margin="0,15,0,0"/>
        </StackLayout>
    </ScrollView>
</abstract:BaseContentPage>