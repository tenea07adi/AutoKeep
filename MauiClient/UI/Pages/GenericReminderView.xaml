<?xml version="1.0" encoding="utf-8" ?>
<abstract:BaseContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="MauiClient.UI.Pages.GenericReminderView"
             xmlns:models="clr-namespace:Core.Entities.Persisted;assembly=Core"
             xmlns:pv="clr-namespace:MauiClient.UI.PartialViews"
             xmlns:abstract="clr-namespace:MauiClient.UI.Abstract"
             xmlns:vm="clr-namespace:MauiClient.ViewModels"
             x:DataType="vm:GenericReminderViewModel"
             Title="Generic Reminder"
             Padding="10">
    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>
    <StackLayout Orientation="Vertical">
        <StackLayout Orientation="Horizontal">
            <Border HorizontalOptions="FillAndExpand">
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding DisplayHistory}" Value="True">
                        <Setter Property="BackgroundColor" Value="{StaticResource Secondary}" />
                    </DataTrigger>
                    <DataTrigger TargetType="Border" Binding="{Binding DisplayHistory}" Value="False">
                        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                    </DataTrigger>
                </Border.Triggers>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ChangeDisplayHistoryCommand}" CommandParameter="{StaticResource False}" />
                </Border.GestureRecognizers>
                <Label Text="Reminder details" Style="{StaticResource SimpleText}" HorizontalOptions="Center">
                </Label>
            </Border>
            <Border HorizontalOptions="FillAndExpand">
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding DisplayHistory}" Value="False">
                        <Setter Property="BackgroundColor" Value="{StaticResource Secondary}" />
                    </DataTrigger>
                    <DataTrigger TargetType="Border" Binding="{Binding DisplayHistory}" Value="True">
                        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                    </DataTrigger>
                </Border.Triggers>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ChangeDisplayHistoryCommand}" CommandParameter="{StaticResource True}" />
                </Border.GestureRecognizers>
                    <Label Text="History" Style="{StaticResource SimpleText}" HorizontalOptions="Center">
                </Label>
            </Border>
        </StackLayout>
        <StackLayout 
            Orientation="Vertical" 
            IsVisible="{Binding DisplayHistory, Converter={StaticResource InvertedBoolConverter}}">
            <Border
                Margin="0,20,0,0">
                <StackLayout Orientation="Vertical">
                    <Label Text="Reminder details" HorizontalOptions="Start" Style="{StaticResource SimpleTextTitle}" 
                   FontAttributes="Bold" TextTransform="Uppercase" />

                    <Border Padding="0"></Border>
                    <pv:DisplayFieldPartialView FieldName="Plate:" FieldValue="{Binding Reminder.Name}" Padding="0,5,0,0" />

                    <pv:DisplayFieldPartialView FieldName="Description:" FieldValue="" Padding="0,5,0,0" />
                    <Label Text="{Binding Reminder.Description}" HorizontalOptions="Start" Style="{StaticResource SimpleText}"  />

                    <Button
                        Grid.Row="0"
                        Text="Delete reminder"
                        Margin="0,15,0,0"
                        BackgroundColor="{StaticResource DangerRed}"
                        Command="{Binding DeleteReminderCommand}" />
                </StackLayout>
            </Border>
            <Border
            Margin="0,20,0,0">
                <StackLayout Orientation="Vertical">
                    <Label Text="Active schedule" HorizontalOptions="Start" Style="{StaticResource SimpleTextTitle}" 
                   FontAttributes="Bold" TextTransform="Uppercase" />
                    <Border Padding="0"></Border>
                    <pv:DisplayFieldPartialView FieldName="Schedule date:" FieldValue="{Binding ActiveSchedule.ScheduledDate, StringFormat='{0:yyyy-MM-dd}'}" Padding="0,5,0,0" />
                    <pv:DisplayFieldPartialView FieldName="Send notifications:" FieldValue="{Binding ActiveSchedule.SendNotifications}" Padding="0,5,0,0" />
                    <pv:DisplayFieldPartialView FieldName="Notifications start before:" FieldValue="{Binding ActiveSchedule.NotificationsStartBeforeInDays}" Format="{}{0:F0} days" Padding="0,5,0,0" />
                    <pv:DisplayFieldPartialView FieldName="Notifications frequency:" FieldValue="{Binding ActiveSchedule.NotificationsIntervalInDays}" Format="{}{0:F0} days" Padding="0,5,0,0" />
                    
                    <Button
                        Grid.Row="0"
                        Text="Reschedule"
                        Margin="0,15,0,0"
                        Command="{Binding NavigateToRescheduleCommand}" />
                </StackLayout>
            </Border>
        </StackLayout>
        <StackLayout Orientation="Vertical" IsVisible="{Binding DisplayHistory}">
            <Border
                Margin="0,20,0,0">
                <StackLayout Orientation="Vertical">
                    <Label Text="History" HorizontalOptions="Start" Style="{StaticResource SimpleTextTitle}" 
                        FontAttributes="Bold" TextTransform="Uppercase" />
                    <Border Padding="0"></Border>
                    <Label 
                        IsVisible="{Binding HaveHistory, Converter={StaticResource InvertedBoolConverter}}"
                        Text="No data" 
                        Style="{StaticResource SimpleText}" 
                        HorizontalOptions="Center"
                        Margin="0,20,0,0"/>
                    <CollectionView 
                        x:Name="RemindersCollectionView"
                        IsVisible="{Binding HaveHistory}"
                        ItemsSource="{Binding OldSchedules}"
                        SelectionMode="None"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill"
                        Margin="0,20,0,0">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Schedule">
                                <Border Margin="0,5,0,0">
                                    <StackLayout Orientation="Vertical" VerticalOptions="Start">
                                        <pv:DisplayFieldPartialView FieldName="Schedule date:" FieldValue="{Binding ScheduledDate, StringFormat='{0:yyyy-MM-dd}'}" Padding="0,5,0,0" />
                                        <pv:DisplayFieldPartialView FieldName="Send notifications:" FieldValue="{Binding SendNotifications}" Padding="0,5,0,0" />
                                    </StackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </StackLayout>
            </Border>
        </StackLayout>
    </StackLayout>
</abstract:BaseContentPage>